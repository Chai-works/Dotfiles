{
    "modules-left": ["clock", "hyprland/window"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": ["tray", "bluetooth", "network", "pulseaudio", "custom/power"],

    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "network": {
        "format-wifi": "{essid} ",
        "format-ethernet": "{ifname} ",
        "format-disconnected": "", 
        "max-length": 50,
        "on-click": "kitty -e 'impala'"
    },
    "hyprland/window": {
    	"format": "{class}",
    },
    "bluetooth": {
        "format": " {status}",
        "format-disabled": "×",
        "format-connected": " {num_connections}",
        "tooltip-format": "{controller_alias}\n{controller_address}",
        "tooltip-format-connected": "{device_enumerate}",
        "on-click": "kitty -e 'bluetui'"
    },
    "hyprland/workspaces": {
         "format": "{icon}",
         "format-icons": {
        	"1": "一",
        	"2": "二",
        	"3": "三",
        	"4": "四",
        	"5": "五",
        	"active": "",
        	"default": ""
    	 },
 	 "all-outputs": true,
    	 "disable-scroll": false,
   	 "show-special": false,
    	 "persistent-workspaces": {
        	"*": 5
    	  }
    },
    "tray": {
        "icon-size": 15,
        "spacing": 10
    },
    "clock": {
        // "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        // "format-alt": "{:%Y-%m-%d}"
		"on-click": "gnome-calendar"
    },
    "pulseaudio": {
        "format": "{volume}% {icon} ",
        "format-bluetooth": "{volume}% {icon} {format_source}",
        "format-bluetooth-muted": " {icon} {format_source}",
        "format-muted": "0% {icon} ",
        "format-source": "{volume}% ",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "kitty -e 'pulsemixer'"
    },
	"custom/power": {
		"format": " ",
		"on-click": "wlogout"
	}
}
